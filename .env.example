# ============================================
# Honeypot-as-a-Service AI Platform Configuration
# ============================================
# Copy to .env and configure

# --- Core ---
SECRET_KEY=your-super-secret-key-change-this
FLASK_CONFIG=development
DATABASE_URL=sqlite:///honeypot.db

# --- Honeypot Ports ---
SSH_HONEYPOT_PORT=2222
HTTP_HONEYPOT_PORT=8080
FTP_HONEYPOT_PORT=2121
WEB_PORT=5000

# --- Redis (for Celery async tasks) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- AI Configuration ---
AI_ENABLED=true
AI_ANOMALY_SENSITIVITY=2.0
AI_MIN_CONFIDENCE=0.3

# --- GeoIP ---
GEOIP_ENABLED=true
GEOIP_DB_PATH=data/GeoLite2-City.mmdb

# --- Threat Intelligence APIs ---
THREAT_INTEL_ENABLED=true
THREAT_INTEL_CACHE_HOURS=24
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# --- Alerting ---
ALERTING_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# --- Distributed Agents ---
AGENT_MODE=standalone
CENTRAL_SERVER_URL=
AGENT_API_KEY=
AGENT_HEARTBEAT_INTERVAL=30

# --- Security ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/hour
SESSION_COOKIE_SECURE=false
WTF_CSRF_ENABLED=true
